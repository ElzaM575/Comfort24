<Page x:Class="Comfort24.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="История продаж"
      Background="#FFFFFF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="900"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <Border Grid.Column="1" 
                Grid.Row="0"
                Background="#D2DFFF"
                CornerRadius="10"
                Margin="0,20,0,20"
                Padding="20">
            <TextBlock x:Name="TitleText" 
                       Text="История реализации продукции"
                       FontSize="32" 
                       FontWeight="Black"
                       Foreground="Black"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Информация о партнере -->
        <Border Grid.Column="1" 
                Grid.Row="1"
                Background="#D2DFFF"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock x:Name="PartnerName" 
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FFFFFF"
                           Margin="0,0,0,10"/>
                <TextBlock x:Name="PartnerInfo" 
                           FontSize="14"
                           Foreground="#FFFFFF"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Статистика -->
        <Border Grid.Column="1" 
                Grid.Row="2"
                Background="#D2DFFF"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Всего продаж" 
                               FontSize="12" 
                               Foreground="Black"/>
                    <TextBlock x:Name="TotalSalesCount" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Всего продукции" 
                               FontSize="12" 
                               Foreground="Black"/>
                    <TextBlock x:Name="TotalProductsCount" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Общая сумма" 
                               FontSize="12" 
                               Foreground="Black"/>
                    <TextBlock x:Name="TotalAmount" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список продаж -->
        <ListView x:Name="SalesListView" 
                  Grid.Column="1"
                  Grid.Row="3"
                  FontSize="14"
                  Margin="0,0,0,20">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Наименование продукции" 
                    Width="300" 
                    DisplayMemberBinding="{Binding ProductName}"/>
                    <GridViewColumn Header="Количество" 
                    Width="100" 
                    DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Header="Сумма" 
                    Width="150" 
                    DisplayMemberBinding="{Binding Amount, StringFormat={}{0:N2}}"/>
                    <GridViewColumn Header="Точка продажи" 
                    Width="200" 
                    DisplayMemberBinding="{Binding PointName}"/>
                    <GridViewColumn Header="Дата" 
                    Width="120" 
                    DisplayMemberBinding="{Binding RequestDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                    <GridViewColumn Header="Статус" 
                    Width="100" 
                    DisplayMemberBinding="{Binding Status}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Сообщение если нет данных -->
        <TextBlock x:Name="EmptyMessage"
                   Grid.Column="1"
                   Grid.Row="3"
                   Text="История продаж отсутствует"
                   FontSize="16"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <!-- Кнопка назад -->
        <StackPanel Grid.Column="1" 
                    Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,30">
            <Button x:Name="BackBtn"
                    Background="#D2DFFF"
                    BorderBrush="#D2DFFF"
                    BorderThickness="1"
                    Height="45"
                    Width="120"
                    Click="BackBtn_Click"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  
                    <TextBlock Text="Назад" FontSize="16" FontWeight="SemiBold" Foreground="Black"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Page>