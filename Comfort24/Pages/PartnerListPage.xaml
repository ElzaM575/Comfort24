<Page x:Class="Comfort24.Pages.PartnerListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Comfort24.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PartnerListPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" 
                Background="#F0F0F0" 
                CornerRadius="10" 
                Padding="15"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" 
                         FontSize="14" 
                         Padding="10"
                         TextChanged="SearchBox_TextChanged"
                         Tag="Поиск по названию, директору или телефону..."/>

                <ComboBox x:Name="FilterCombo" 
                          Grid.Column="1" 
                          Width="200"
                          Height="40"
                          Margin="10,0"
                          FontSize="14"
                          SelectionChanged="FilterCombo_SelectionChanged"
                          DisplayMemberPath="NameBusiness"
                          SelectedValuePath="Id_type_business">
                    <ComboBoxItem Content="Все типы" Tag="all" IsSelected="True"/>
                </ComboBox>

                <Button x:Name="ClearFilterBtn" 
                        Grid.Column="2"
                        Content="✖ Сбросить"
                        Width="100"
                        Height="40"
                        Background="#355CBD"
                        Foreground="White"
                        Cursor="Hand"
                        Click="ClearFilterBtn_Click"/>
            </Grid>
        </Border>

        <ListView x:Name="PartnersLW"
                   Grid.Row="2"
                  FontSize="20">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" 
                            BorderThickness="1" Margin="10">
                        <Grid Margin="10" Width="700">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" >
                                <TextBlock Text="{Binding TypeOfBusiness.NameBusiness}"/>
                                <TextBlock Text=" | " />
                                <TextBlock Text="{Binding NamePartner}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding SurnameDirector}"/>
                                <TextBlock Text="{Binding NameDirector}"/>
                                <TextBlock Text="{Binding PatronumicDirector}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="{Binding Phone}" />
                            <TextBlock Grid.Row="3" Text="{Binding Raiting}" />
                            <TextBlock Grid.Row="0" Text="{Binding SizeDiscount }" Grid.Column="1" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Orientation="Horizontal" Grid.Row="3" >
            <Button x:Name="AddBtn" Click="AddBtn_Click_1">Добавить</Button>
            <Button x:Name="EditBtn" Click="EditBtn_Click_1">Изменить</Button>
            <Button x:Name="DeleteBtn" Click="DeleteBtn_Click">Удалить</Button>
            <Button x:Name="historyBtn" Click="historyBtn_Click" >История</Button>
        </StackPanel>
    </Grid>
</Page>
