<Page x:Class="Comfort24.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Comfort24.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="800"
      Title="RegPage">

    <Grid>
        <ScrollViewer>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="900"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1" 
                    Grid.Row="0"
                    Background="#D2DFFF "
                    CornerRadius="10"
                    Margin="0,30,0,30"
                    Padding="20">
                    <TextBlock Text="Регистрация нового сотрудника" 
                           FontSize="36" 
                           FontWeight="Black"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
                </Border>


                <Grid Grid.Column="1" 
                  Grid.Row="1"
                  Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Border Background="#F0F0F0"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Данные для входа" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Foreground="#2D6033"
                                       Margin="0,0,0,15"/>

                                <TextBlock Text="Логин *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="login" 
                                     Height="45"
                                     FontSize="16"
                                     Padding="10,5"
                                     Margin="0,0,0,15"/>

                                <TextBlock Text="Пароль *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <PasswordBox x:Name="password" 
                                         Height="45"
                                         FontSize="16"
                                         Padding="10,5"/>
                            </StackPanel>
                        </Border>

                        <!-- Блок личных данных -->
                        <Border Background="#F0F0F0"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Личные данные" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Foreground="#2D6033"
                                       Margin="0,0,0,15"/>

                                <TextBlock Text="Фамилия *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="surname" 
                                     Height="45"
                                     FontSize="16"
                                     Padding="10,5"
                                     Margin="0,0,0,15"/>
                                <TextBlock Text="Имя *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="name" 
                                     Height="45"
                                     FontSize="16"
                                     Padding="10,5"
                                     Margin="0,0,0,15"/>
                                <TextBlock Text="Отчество" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="patronymic" 
                                     Height="45"
                                     FontSize="16"
                                     Padding="10,5"
                                     Margin="0,0,0,15"/>
                                <TextBlock Text="Дата рождения *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <DatePicker x:Name="birthday" 
                                        Height="45"
                                        FontSize="16"
                                        Margin="0,0,0,15"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Border Background="#F0F0F0"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Паспортные данные" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Foreground="#2D6033"
                                       Margin="0,0,0,15"/>

                                <TextBlock Text="Серия паспорта *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="passportSeries" 
                                     Height="45"
                                     FontSize="16"
                                     Padding="10,5"
                                     MaxLength="10"
                                     Margin="0,0,0,15"/>
                                <TextBlock Text="Номер паспорта *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="passportNumber" 
                                     Height="45"
                                     FontSize="16"
                                     Padding="10,5"
                                     MaxLength="20"
                                     Margin="0,0,0,15"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F0F0F0"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Дополнительная информация" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Foreground="#2D6033"
                                       Margin="0,0,0,15"/>

                                <TextBlock Text="Семейное положение *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <ComboBox x:Name="familyStatusCombo" 
                                      Height="45"
                                      FontSize="16"
                                      DisplayMemberPath="NameStatus"
                                      SelectedValuePath="StatusID"
                                      Margin="0,0,0,15"/>

                                <TextBlock Text="Состояние здоровья *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <ComboBox x:Name="healthCombo" 
                                      Height="45"
                                      FontSize="16"
                                      DisplayMemberPath="NameHealth"
                                      SelectedValuePath="HealthID"
                                      Margin="0,0,0,15"/>
                                <TextBlock Text="Должность *" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <ComboBox x:Name="positionCombo" 
                                      Height="45"
                                      FontSize="16"
                                      DisplayMemberPath="NamePosition"
                                      SelectedValuePath="PositionID"
                                      Margin="0,0,0,15"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" 
                        Grid.Row="2"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,30">

                    <TextBlock Text="* - обязательные поля" 
                           FontSize="12"
                           Foreground="Gray"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>


                    <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center">

                        <Button x:Name="registration" 
                            Background="#355CBD" 
                            Content="Зарегистрироваться" 
                            FontSize="16"  
                            Height="45"
                            Width="180"
                            Click="registration_Click"
                            Margin="0,0,10,0"
                            Cursor="Hand"/>

                        <Button x:Name="back" 
                            Background="White" 
                            Content="Назад" 
                            FontSize="16"  
                            Height="45"
                            Width="120"
                            FontWeight="Bold" 
                            Foreground="#355CBD"
                            Click="back_Click"
                            BorderBrush="#355CBD"
                            BorderThickness="1"
                            Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
